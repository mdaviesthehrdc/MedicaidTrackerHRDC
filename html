    <!-- IN-MEMORY & STORAGE JAVASCRIPT STATE CONTROLLER -->
    <script>
        // Default Local Storage Setup
        const defaultProfile = {
            name: "John Doe",
            caseId: "74859",
            medid: "MT-482939",
            phone: "(406) 586-7600"
        };

        let profile = JSON.parse(localStorage.getItem('hrdc_medicaid_profile')) || defaultProfile;
        let logs = JSON.parse(localStorage.getItem('hrdc_medicaid_logs')) || [];

        // Digital Signature variables
        let canvas, ctx;
        let drawing = false;
        let hasSigned = false;

        window.onload = function() {
            // Setup Profile Details
            syncProfileUI();

            // Setup Date input default to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('form-date').value = today;

            // Load Hours Logs Table
            renderHistoryTable();
            updateDashboard();

            // Initialize Signature Pad
            initSignatureCanvas();

            // Listen for window resize to fix canvas scaling
            window.addEventListener('resize', handleCanvasResize);
        };

        // UI Tabs Switcher
        function switchTab(tabId) {
            // Hide all tab views
            const views = document.querySelectorAll('.tab-view');
            views.forEach(v => v.classList.add('hidden'));

            // Show targets
            const activeView = document.getElementById('view-' + tabId);
            if (activeView) activeView.classList.remove('hidden');

            // Reset tab button stylings
            const tabBtns = document.querySelectorAll('.tab-btn');
            tabBtns.forEach(btn => {
                btn.classList.remove('text-emerald-600', 'border-emerald-600');
                btn.classList.add('text-slate-500', 'border-transparent');
            });

            // Set active button style
            const activeBtn = document.getElementById('tab-' + tabId);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-500', 'border-transparent');
                activeBtn.classList.add('text-emerald-600', 'border-emerald-600');
            }

            // Custom initializations on tab load
            if (tabId === 'verification-sheet') {
                preparePrintSheet();
            }
        }

        // Profile Modal controllers
        function openProfileModal() {
            document.getElementById('modal-user-name').value = profile.name;
            document.getElementById('modal-case-id').value = profile.caseId;
            document.getElementById('modal-medid').value = profile.medid;
            document.getElementById('modal-phone').value = profile.phone;

            document.getElementById('profile-modal').classList.remove('hidden');
        }

        function closeProfileModal() {
            document.getElementById('profile-modal').classList.add('hidden');
        }

        function saveProfile() {
            profile.name = document.getElementById('modal-user-name').value.trim() || "N/A";
            profile.caseId = document.getElementById('modal-case-id').value.trim() || "N/A";
            profile.medid = document.getElementById('modal-medid').value.trim() || "N/A";
            profile.phone = document.getElementById('modal-phone').value.trim() || "N/A";

            localStorage.setItem('hrdc_medicaid_profile', JSON.stringify(profile));
            syncProfileUI();
            closeProfileModal();
            showToast("Profile details updated successfully!");

            // Refresh sheets
            preparePrintSheet();
        }

        function syncProfileUI() {
            document.getElementById('header-user-name').innerText = profile.name;
            document.getElementById('header-user-case').innerText = profile.caseId;
            document.getElementById('header-user-medid').innerText = profile.medid;

            // Fill sheet placeholders
            document.getElementById('sheet-user-name').innerText = profile.name;
            document.getElementById('sheet-case-id').innerText = profile.caseId;
            document.getElementById('sheet-medicaid-id').innerText = profile.medid;
            document.getElementById('sheet-user-phone').innerText = profile.phone;
        }

        // Interactive Signature Pad Implementation
        function initSignatureCanvas() {
            canvas = document.getElementById('signature-canvas');
            if (!canvas) return;
            ctx = canvas.getContext('2d');
            
            // Adjust dimensions
            handleCanvasResize();

            // Set drawing styling
            ctx.lineWidth = 2.5;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.strokeStyle = '#064e3b'; // dark emerald color

            // Event Listeners for drawing
            canvas.addEventListener('mousedown', startDrawing);
            canvas.addEventListener('mouseup', endDrawing);
            canvas.addEventListener('mousemove', draw);

            // Add touchscreen support
            canvas.addEventListener('touchstart', (e) => {
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousedown', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                canvas.dispatchEvent(mouseEvent);
                e.preventDefault();
            }, { passive: false });

            canvas.addEventListener('touchend', (e) => {
                const mouseEvent = new MouseEvent('mouseup', {});
                canvas.dispatchEvent(mouseEvent);
                e.preventDefault();
            }, { passive: false });

            canvas.addEventListener('touchmove', (e) => {
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousemove', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                canvas.dispatchEvent(mouseEvent);
                e.preventDefault();
            }, { passive: false });
        }

        function handleCanvasResize() {
            if (!canvas) return;
            const rect = canvas.getBoundingClientRect();
            // Scale resolution to prevent blurs
            canvas.width = rect.width;
            canvas.height = rect.height;
            // Clear signature on resize to maintain integrity
            clearSignatureCanvas();
        }

        function startDrawing(e) {
            drawing = true;
            hasSigned = true;
            ctx.beginPath();
            const pos = getMousePos(e);
            ctx.moveTo(pos.x, pos.y);
        }

        function endDrawing() {
            drawing = false;
        }

        function draw(e) {
            if (!drawing) return;
            const pos = getMousePos(e);
            ctx.lineTo(pos.x, pos.y);
            ctx.stroke();
        }

        function getMousePos(e) {
            const rect = canvas.getBoundingClientRect();
            return {
                x: e.clientX - rect.left,
                y: e.clientY - rect.top
            };
        }

        function clearSignatureCanvas() {
            if (!canvas || !ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            hasSigned = false;
        }

        // Save Form Logs Logic
        function saveHourEntry(e) {
            e.preventDefault();

            const date = document.getElementById('form-date').value;
            const activityType = document.getElementById('form-activity-type').value;
            const site = document.getElementById('form-site').value;
            const hours = parseFloat(document.getElementById('form-hours').value);
            const desc = document.getElementById('form-description').value.trim();
            const supName = document.getElementById('form-sup-name').value.trim();
            const supContact = document.getElementById('form-sup-contact').value.trim();

            if (isNaN(hours) || hours <= 0) {
                showToast("Please enter a valid amount of hours.");
                return;
            }

            // Capture signature image payload
            let signatureData = null;
            if (hasSigned) {
                signatureData = canvas.toDataURL();
            }

            const newEntry = {
                id: Date.now().toString(),
                date,
                activityType,
                site,
                hours,
                description: desc,
                supervisor: supName,
                contact: supContact,
                signature: signatureData
            };

            logs.push(newEntry);
            localStorage.setItem('hrdc_medicaid_logs', JSON.stringify(logs));

            // Reset state
            document.getElementById('hour-log-form').reset();
            clearSignatureCanvas();
            document.getElementById('form-date').value = new Date().toISOString().split('T')[0];

            showToast("Hour entry logged to your history.");
            
            // Re-render components
            renderHistoryTable();
            updateDashboard();
            switchTab('history');
        }

        // Dashboard Metrics update logic
        function updateDashboard() {
            // Find total hours logged
            let total = 0;
            let totalCS = 0;
            let totalVol = 0;
            let totalJob = 0;
            let totalEmp = 0;

            logs.forEach(log => {
                total += log.hours;
                if (log.activityType === "Community Service") totalCS += log.hours;
                else if (log.activityType === "Volunteering") totalVol += log.hours;
                else if (log.activityType === "Workforce Development") totalJob += log.hours;
                else if (log.activityType === "Employment/Education") totalEmp += log.hours;
            });

            // Update stats
            document.getElementById('dash-total-hours').innerText = total.toFixed(1);
            document.getElementById('dash-total-entries').innerText = `${logs.length} Logs`;

            // Calculate progress bar width (capped at 100)
            const progressPct = Math.min((total / 80) * 100, 100);
            document.getElementById('dash-progress-bar').style.width = `${progressPct}%`;

            // Calculate needed hours
            const remaining = Math.max(80 - total, 0);
            document.getElementById('dash-hours-needed').innerText = remaining.toFixed(1);

            const badge = document.getElementById('dash-status-badge');
            if (total >= 80) {
                badge.innerText = "Congratulations! You have achieved your 80-hour Medicaid Community Engagement goal for this month.";
                badge.className = "bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-lg p-3 text-xs mt-2 text-center font-bold";
            } else {
                badge.innerHTML = `Still need <strong class="font-bold">${remaining.toFixed(1)}</strong> hours to hit your goal this month.`;
                badge.className = "bg-amber-50 text-amber-700 border border-amber-200 rounded-lg p-3 text-xs mt-2 text-center font-medium";
            }

            // Update category breakdowns
            document.getElementById('breakdown-cs').innerText = `${totalCS.toFixed(1)} hrs`;
            document.getElementById('breakdown-vol').innerText = `${totalVol.toFixed(1)} hrs`;
            document.getElementById('breakdown-job').innerText = `${totalJob.toFixed(1)} hrs`;
            document.getElementById('breakdown-emp').innerText = `${totalEmp.toFixed(1)} hrs`;

            // Calculate days left in active month (simulate July 2026 current date target setup)
            const today = new Date("2026-07-06");
            const endOfMonth = new Date("2026-07-31");
            const diffTime = Math.abs(endOfMonth - today);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            document.getElementById('dash-days-left').innerText = `${diffDays} Days`;
        }

        // Render logs in the Verification log history tab
        function renderHistoryTable() {
            const tbody = document.getElementById('history-table-body');
            const emptyState = document.getElementById('history-empty-state');
            const filter = document.getElementById('filter-activity').value;

            tbody.innerHTML = '';

            let filteredLogs = logs;
            if (filter !== 'All') {
                filteredLogs = logs.filter(l => l.activityType === filter);
            }

            if (filteredLogs.length === 0) {
                emptyState.classList.remove('hidden');
                return;
            } else {
                emptyState.classList.add('hidden');
            }

            // Sort logs by date descending
            filteredLogs.sort((a, b) => new Date(b.date) - new Date(a.date));

            filteredLogs.forEach(log => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50 transition duration-150";

                // Format signature display
                let sigMarkup = `<span class="text-xs text-amber-500 italic font-semibold">Pending</span>`;
                if (log.signature) {
                    sigMarkup = `<img src="${log.signature}" class="h-6 w-16 mx-auto object-contain border border-slate-200 rounded bg-white p-0.5" alt="Sig" />`;
                }

                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-xs font-bold text-slate-800">${log.date}</div>
                        <div class="text-[10px] text-slate-500 font-semibold">${log.site}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2.5 py-0.5 inline-flex text-[9px] leading-5 font-bold rounded-full ${getActivityBadgeStyle(log.activityType)}">
                            ${log.activityType}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <p class="text-xs text-slate-600 font-medium max-w-xs truncate">${log.description}</p>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-xs font-bold text-slate-800">
                        ${log.hours.toFixed(1)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-xs font-semibold text-slate-800">${log.supervisor}</div>
                        <div class="text-[10px] text-slate-400">${log.contact}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                        ${sigMarkup}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-xs font-medium">
                        <button onclick="deleteLogEntry('${log.id}')" class="text-rose-600 hover:text-rose-900 font-bold ml-2">Delete</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function getActivityBadgeStyle(type) {
            switch(type) {
                case 'Community Service': return 'bg-amber-100 text-amber-800';
                case 'Volunteering': return 'bg-emerald-100 text-emerald-800';
                case 'Workforce Development': return 'bg-indigo-100 text-indigo-800';
                case 'Employment/Education': return 'bg-sky-100 text-sky-800';
                default: return 'bg-slate-100 text-slate-800';
            }
        }

        function deleteLogEntry(id) {
            logs = logs.filter(l => l.id !== id);
            localStorage.setItem('hrdc_medicaid_logs', JSON.stringify(logs));
            renderHistoryTable();
            updateDashboard();
            showToast("Log entry deleted successfully.");
        }

        function clearAllLogs() {
            if (confirm("Are you sure you want to clear your hours logging history? This cannot be undone.")) {
                logs = [];
                localStorage.removeItem('hrdc_medicaid_logs');
                renderHistoryTable();
                updateDashboard();
                showToast("Cleared all timesheet data logs.");
            }
        }

        // Preparation of the printable preview sheet
        function preparePrintSheet() {
            const sheetBody = document.getElementById('sheet-table-body');
            sheetBody.innerHTML = '';

            let total = 0;

            if (logs.length === 0) {
                sheetBody.innerHTML = `
                    <tr>
                        <td colspan="7" class="py-8 text-center text-slate-400 italic">No community service hours logged for the active verification period.</td>
                    </tr>
                `;
                document.getElementById('sheet-total-hours').innerText = "0.0";
                return;
            }

            // Sort logs chronologically for printing
            const sortedLogs = [...logs].sort((a, b) => new Date(a.date) - new Date(b.date));

            sortedLogs.forEach(log => {
                total += log.hours;
                const tr = document.createElement('tr');
                tr.className = "border-b border-slate-200";

                let signatureCell = `<span class="text-[10px] text-slate-300 italic">Pending Manual Sign</span>`;
                if (log.signature) {
                    signatureCell = `<img src="${log.signature}" class="h-6 max-w-[80px] mx-auto object-contain" alt="Sig" />`;
                }

                tr.innerHTML = `
                    <td class="py-2.5 px-3 whitespace-nowrap font-semibold">${log.date}</td>
                    <td class="py-2.5 px-3">${log.site}</td>
                    <td class="py-2.5 px-3 font-semibold text-slate-600">${log.activityType}</td>
                    <td class="py-2.5 px-3 text-[11px] text-slate-500">${log.description}</td>
                    <td class="py-2.5 px-3 text-center font-bold">${log.hours.toFixed(1)}</td>
                    <td class="py-2.5 px-3">${log.supervisor} (${log.contact})</td>
                    <td class="py-2.5 px-3 text-center">${signatureCell}</td>
                `;
                sheetBody.appendChild(tr);
            });

            document.getElementById('sheet-total-hours').innerText = total.toFixed(1);

            // Populate high resolution print stylesheet target elements
            const fullSheetClone = document.getElementById('view-verification-sheet').querySelector('.border-slate-300').cloneNode(true);
            document.getElementById('print-sheet-content').innerHTML = '';
            document.getElementById('print-sheet-content').appendChild(fullSheetClone);
        }

        // System notification custom handler (no alert block bypass)
        function showToast(message) {
            const toast = document.getElementById('toast-notif');
            document.getElementById('toast-text').innerText = message;
            
            // Pop up animations
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3500);
        }
    </script>
</body>
</html>
