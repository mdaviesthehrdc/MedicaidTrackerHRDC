<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HRDC Medicaid Volunteer & Hour Tracking Portal</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            .print-only {
                display: block !important;
            }
            body {
                background: white !important;
                color: black !important;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col antialiased">

    <!-- TOP HEADER / BRANDING -->
    <header class="bg-emerald-900 text-white shadow-md no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center space-x-3">
                <div class="bg-white p-2 rounded-lg shadow-inner">
                    <!-- Custom SVG representing HRDC & Community Health -->
                    <svg class="w-8 h-8 text-emerald-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-tight">HRDC District IX</h1>
                    <p class="text-xs text-emerald-200">Medicaid Expansion Hour Verification Portal</p>
                </div>
            </div>
            <div class="flex items-center space-x-2 bg-emerald-850 px-3 py-1.5 rounded-full text-xs font-semibold text-emerald-100 border border-emerald-700">
                <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse"></span>
                <span>Active Tracking Period: July – September 2026</span>
            </div>
        </div>
    </header>

    <!-- MAIN APP WRAPPER -->
    <main id="app" class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 no-print">
        
        <!-- MAIN NAVIGATION TABS -->
        <div class="border-b border-slate-200 mb-6">
            <nav class="flex flex-wrap -mb-px space-x-2 sm:space-x-4" aria-label="Tabs">
                <button onclick="switchTab('dashboard')" id="tab-dashboard" class="tab-btn border-b-2 py-3 px-4 text-sm font-medium transition-all duration-150 flex items-center space-x-2 text-emerald-600 border-emerald-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z"></path></svg>
                    <span>Dashboard</span>
                </button>
                <button onclick="switchTab('form')" id="tab-form" class="tab-btn border-b-2 py-3 px-4 text-sm font-medium transition-all duration-150 flex items-center space-x-2 text-slate-500 border-transparent hover:text-slate-700 hover:border-slate-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Log New Hours</span>
                </button>
                <button onclick="switchTab('history')" id="tab-history" class="tab-btn border-b-2 py-3 px-4 text-sm font-medium transition-all duration-150 flex items-center space-x-2 text-slate-500 border-transparent hover:text-slate-700 hover:border-slate-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    <span>Verification Log</span>
                </button>
                <button onclick="switchTab('verification-sheet')" id="tab-verification-sheet" class="tab-btn border-b-2 py-3 px-4 text-sm font-medium transition-all duration-150 flex items-center space-x-2 text-slate-500 border-transparent hover:text-slate-700 hover:border-slate-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 05-2-2H9a2 2 0 05-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    <span>Print State Form</span>
                </button>
                <button onclick="switchTab('faq')" id="tab-faq" class="tab-btn border-b-2 py-3 px-4 text-sm font-medium transition-all duration-150 flex items-center space-x-2 text-slate-500 border-transparent hover:text-slate-700 hover:border-slate-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Rules & FAQs</span>
                </button>
            </nav>
        </div>

        <!-- PROFILE CONFIGURATION BANNER (State Persisted) -->
        <section class="bg-white border border-slate-200 rounded-xl p-4 mb-6 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex items-center space-x-3">
                <div class="bg-indigo-50 p-2.5 rounded-lg text-indigo-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800 text-sm md:text-base" id="header-user-name">Configuring Volunteer Log...</h3>
                    <p class="text-xs text-slate-500">Case #<span id="header-user-case">N/A</span> | Medicaid ID: <span id="header-user-medid">N/A</span></p>
                </div>
            </div>
            <button onclick="openProfileModal()" class="text-xs bg-slate-150 hover:bg-slate-200 text-slate-700 font-medium px-4 py-2 rounded-lg transition-all border border-slate-300 flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Change Personal Info
            </button>
        </section>

        <!-- ================== 1. DASHBOARD VIEW ================== -->
        <div id="view-dashboard" class="tab-view space-y-6">
            <!-- Montana DPHHS Hold Harmless Notice Banner -->
            <div class="bg-gradient-to-r from-amber-50 to-amber-100 border-l-4 border-amber-500 p-4 rounded-r-xl shadow-sm">
                <div class="flex">
                    <div class="flex-shrink-0 text-amber-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-bold text-amber-900">Montana DPHHS "Hold Harmless" Status Announcement (2026)</h3>
                        <p class="mt-1 text-xs text-amber-800 leading-relaxed">
                            From July through September 2026, Montana DPHHS has implemented a <strong>hold harmless period</strong> for the newly activated community engagement rules. Your Medicaid coverage will not be dis-enrolled for reporting deficits during this phase, but hours must still be actively tracked and reported to demonstrate readiness for mandatory compliance enforcement starting in <strong>October 2026</strong>.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Dashboard Statistics and Progress Widgets -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Circular/Semi-Circular/Card Progress tracker towards 80 hours -->
                <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm flex flex-col justify-between">
                    <div>
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Monthly Requirement Progress</h4>
                        <h2 class="text-2xl font-extrabold text-slate-800">80 Hour Goal</h2>
                        <p class="text-xs text-slate-500 mt-1 mb-4">Required each calendar month for Medicaid Expansion enrollees aged 19-64.</p>
                    </div>

                    <!-- Progress Bar Component -->
                    <div class="my-4">
                        <div class="flex justify-between items-end mb-2">
                            <span class="text-3xl font-black text-emerald-600" id="dash-total-hours">0.0</span>
                            <span class="text-xs font-bold text-slate-500">of 80.0 Hours Completed</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden border border-slate-200 shadow-inner">
                            <div id="dash-progress-bar" class="bg-emerald-600 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                        </div>
                        <div class="flex justify-between text-[10px] text-slate-400 font-semibold mt-2">
                            <span>0 Hrs</span>
                            <span>40 Hrs (50%)</span>
                            <span>80 Hrs Goal</span>
                        </div>
                    </div>

                    <div id="dash-status-badge" class="bg-amber-50 text-amber-700 border border-amber-200 rounded-lg p-3 text-xs mt-2 text-center font-medium">
                        Still need <span id="dash-hours-needed" class="font-bold">80.0</span> hours to hit your goal this month.
                    </div>
                </div>

                <!-- Fast Info metrics grid -->
                <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm flex flex-col justify-between col-span-1 lg:col-span-2">
                    <div>
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Active Month Status Summary</h4>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 my-3">
                            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                                <span class="text-xs text-slate-500 block font-medium">Month Period</span>
                                <span class="text-lg font-bold text-slate-800" id="dash-current-month">July 2026</span>
                            </div>
                            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                                <span class="text-xs text-slate-500 block font-medium">Total Entries</span>
                                <span class="text-lg font-bold text-slate-800" id="dash-total-entries">0 Logs</span>
                            </div>
                            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                                <span class="text-xs text-slate-500 block font-medium">Days Left in Month</span>
                                <span class="text-lg font-bold text-slate-800" id="dash-days-left">25 Days</span>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-slate-100 pt-4 mt-4">
                        <h5 class="text-xs font-bold text-slate-500 uppercase mb-3">Qualifying HRDC Category Breakdown</h5>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                            <div class="bg-emerald-50/50 p-2.5 rounded-lg border border-emerald-100">
                                <span class="text-[10px] font-bold text-emerald-800 block">Community Service</span>
                                <span class="text-sm font-bold text-slate-800" id="breakdown-cs">0.0 hrs</span>
                            </div>
                            <div class="bg-teal-50/50 p-2.5 rounded-lg border border-teal-100">
                                <span class="text-[10px] font-bold text-teal-800 block">Volunteering</span>
                                <span class="text-sm font-bold text-slate-800" id="breakdown-vol">0.0 hrs</span>
                            </div>
                            <div class="bg-indigo-50/50 p-2.5 rounded-lg border border-indigo-100">
                                <span class="text-[10px] font-bold text-indigo-800 block">Workforce Dev</span>
                                <span class="text-sm font-bold text-slate-800" id="breakdown-job">0.0 hrs</span>
                            </div>
                            <div class="bg-sky-50/50 p-2.5 rounded-lg border border-sky-100">
                                <span class="text-[10px] font-bold text-sky-800 block">Employment/Edu</span>
                                <span class="text-sm font-bold text-slate-800" id="breakdown-emp">0.0 hrs</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Fast Action & HRDC Specific Service Locations -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Log quick guidance card -->
                <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm flex flex-col justify-between">
                    <div>
                        <h4 class="font-bold text-slate-800 mb-2">Need to verify hours on-the-spot?</h4>
                        <p class="text-slate-600 text-sm leading-relaxed mb-4">
                            You can log your service sessions right inside this app. If you have your site coordinator or HRDC supervisor nearby, switch to the <strong>Log New Hours</strong> tab and they can physically sign off on your timesheet directly on your smartphone, tablet, or computer screen.
                        </p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <button onclick="switchTab('form')" class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded-lg text-sm text-center transition duration-150 flex items-center justify-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Log New Hours Entry
                        </button>
                        <button onclick="switchTab('verification-sheet')" class="bg-slate-100 hover:bg-slate-200 text-slate-700 border border-slate-300 font-semibold py-2 px-4 rounded-lg text-sm text-center transition duration-150 flex items-center justify-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 05-2-2H9a2 2 0 05-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                            Generate Printable Form
                        </button>
                    </div>
                </div>

                <!-- HRDC Official Programs Catalog -->
                <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                    <h4 class="font-bold text-slate-800 mb-3">Qualifying HRDC Programs / Contact Info</h4>
                    <div class="space-y-3 max-h-60 overflow-y-auto pr-1">
                        <div class="p-2.5 hover:bg-slate-50 rounded-lg border border-slate-100 transition duration-150">
                            <div class="flex justify-between items-start">
                                <span class="font-semibold text-xs text-slate-800">Gallatin Valley Food Bank</span>
                                <span class="text-[9px] bg-emerald-100 text-emerald-800 px-1.5 py-0.5 rounded-full font-bold">Bozeman, MT</span>
                            </div>
                            <p class="text-[11px] text-slate-500 mt-1">Accepts community service & volunteers. Scheduling shifts in advance required.</p>
                        </div>
                        <div class="p-2.5 hover:bg-slate-50 rounded-lg border border-slate-100 transition duration-150">
                            <div class="flex justify-between items-start">
                                <span class="font-semibold text-xs text-slate-800">Fork & Spoon Community Oven</span>
                                <span class="text-[9px] bg-emerald-100 text-emerald-800 px-1.5 py-0.5 rounded-full font-bold">Bozeman, MT</span>
                            </div>
                            <p class="text-[11px] text-slate-500 mt-1">Montana's pay-what-you-can dinner model. Great evening shifts for hours tracking.</p>
                        </div>
                        <div class="p-2.5 hover:bg-slate-50 rounded-lg border border-slate-100 transition duration-150">
                            <div class="flex justify-between items-start">
                                <span class="font-semibold text-xs text-slate-800">Homeward Point Emergency Shelter</span>
                                <span class="text-[9px] bg-emerald-100 text-emerald-800 px-1.5 py-0.5 rounded-full font-bold">Bozeman, MT</span>
                            </div>
                            <p class="text-[11px] text-slate-500 mt-1">Shelter and drop-in support. Shifts support vulnerable neighbors directly.</p>
                        </div>
                        <div class="p-2.5 hover:bg-slate-50 rounded-lg border border-slate-100 transition duration-150">
                            <div class="flex justify-between items-start">
                                <span class="font-semibold text-xs text-slate-800">Headwaters Area Food Bank</span>
                                <span class="text-[9px] bg-emerald-100 text-emerald-800 px-1.5 py-0.5 rounded-full font-bold">Three Forks, MT</span>
                            </div>
                            <p class="text-[11px] text-slate-500 mt-1">Supports community service & nutrition outreach projects in Broadwater/Gallatin.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================== 2. HOUR LOGGING FORM VIEW ================== -->
        <div id="view-form" class="tab-view hidden max-w-3xl mx-auto">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
                <div class="bg-emerald-850 bg-emerald-900 text-white p-6">
                    <h3 class="text-lg font-bold">Log Volunteer/Community Engagement Hours</h3>
                    <p class="text-xs text-emerald-100 mt-1">Submit complete and honest logs. Supervisor signature confirmation can be obtained digitally below or printed later.</p>
                </div>
                
                <form id="hour-log-form" onsubmit="saveHourEntry(event)" class="p-6 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1">Date of Activity *</label>
                            <input type="date" id="form-date" required class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1">Activity Classification *</label>
                            <select id="form-activity-type" required class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm bg-white">
                                <option value="Community Service">Required Community Service / Court Order</option>
                                <option value="Volunteering" selected>Volunteering (Standard Public Interest)</option>
                                <option value="Workforce Development">Workforce Training / Job Preparedness</option>
                                <option value="Employment/Education">Regular Employment or Education Hours</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1">HRDC Service Site *</label>
                            <select id="form-site" required class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm bg-white">
                                <option value="Gallatin Valley Food Bank">Gallatin Valley Food Bank (Bozeman)</option>
                                <option value="Fork & Spoon Community Oven">Fork & Spoon Community Oven</option>
                                <option value="Homeward Point Emergency Shelter">Homeward Point Shelter</option>
                                <option value="Big Sky Community Food Bank">Big Sky Community Food Bank</option>
                                <option value="Headwaters Area Food Bank">Headwaters Area Food Bank (Three Forks)</option>
                                <option value="HRDC Community Gardens">HRDC Gardens & Nutrition projects</option>
                                <option value="Other Non-HRDC Approved Site">Other Approved Community Site (Custom)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1">Total Hours Worked *</label>
                            <div class="flex items-center space-x-2">
                                <input type="number" id="form-hours" min="0.5" max="24" step="0.5" required placeholder="e.g. 3.5" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm">
                                <span class="text-sm font-semibold text-slate-500">hours</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1">Task description / Accomplishments *</label>
                        <textarea id="form-description" required rows="2" placeholder="Explain tasks performed (e.g., sorted food drive shelf, prepared meals, registered clients)" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"></textarea>
                    </div>

                    <div class="border-t border-slate-200 pt-4">
                        <h4 class="text-sm font-bold text-slate-800 mb-2">Supervisor/Coordinator Validation Information</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wide mb-1">Supervisor Full Name *</label>
                                <input type="text" id="form-sup-name" required placeholder="Supervisor name" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wide mb-1">Contact Email or Phone Number *</label>
                                <input type="text" id="form-sup-contact" required placeholder="Email or Phone" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm">
                            </div>
                        </div>

                        <!-- Touch Signature Field with canvas -->
                        <div class="space-y-1">
                            <div class="flex justify-between items-center">
                                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wide">Digital On-Screen Sign-Off (Optional)</label>
                                <button type="button" onclick="clearSignatureCanvas()" class="text-[10px] text-rose-600 hover:text-rose-800 font-bold transition">Clear Canvas</button>
                            </div>
